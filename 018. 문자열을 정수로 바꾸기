문제 설명
문자열 s를 숫자로 변환한 결과를 반환하는 함수, solution을 완성하세요.

제한 조건
● s의 길이는 1 이상 5이하입니다.
● s의 맨앞에는 부호(+, -)가 올 수 있습니다.
● s는 부호와 숫자로만 이루어져있습니다.
● s는 "0"으로 시작하지 않습니다.

입출력 예
예를들어 str이 "1234"이면 1234를 반환하고, "-1234"이면 -1234를 반환하면 됩니다.
str은 부호(+,-)와 숫자로만 구성되어 있고, 잘못된 값이 입력되는 경우는 없습니다.

//C
#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>

int solution(const char* s) {
    int answer = 0;
    int i = 0;
    int sign = 1;
    
    if (s[0] == '+') {
        i = 1;
    }
    else if (s[0] == '-') {
        i = 1;
        sign = -1;
    }
    
    for(; s[i] != '\0'; ++i) {
        answer = answer * 10 + (s[i] - '0');
    }
    
    return answer * sign;                  //return atoi(s); 혹은 return (int)strtol(s, NULL, 10); 으로 표현 가능
}

//C++
#include <string>
#include <vector>

using namespace std;

int solution(string s) {
    int answer = 0;
    int i = 0;
    int sign = 1;
    
    if (s[0] == '+') {
        i = 1;
    }
    else if (s[0] == '-') {
        i = 1;
        sign = -1;
    }
    
    for(; i < s.size(); ++i) {
        answer = answer * 10 + (s[i] - '0');
    }
    
    return answer * sign;                        //return stoi(s); 한 줄로 표현 가능
}

//C#
public class Solution {
    public int solution(string s) {
        int answer = 0;
        int i = 0;
        int sign = 1;
    
        if (s[0] == '+') {
            i = 1;
        }
        else if (s[0] == '-') {
            i = 1;
            sign = -1;
        }
    
        for(; i < s.Length; ++i) {
            answer = answer * 10 + (s[i] - '0');
