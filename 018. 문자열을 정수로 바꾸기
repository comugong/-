    }
}

//Java
class Solution {
    public int solution(String s) {
        int answer = 0;
        int i = 0;
        int sign = 1;
    
        if (s.charAt(0) == '+') {
            i = 1;
        }
        else if (s.charAt(0) == '-') {
            i = 1;
            sign = -1;
        }
    
        for(; i < s.length(); ++i) {
            answer = answer * 10 + (s.charAt(i) - '0');
        }
    
        return answer * sign;                     //return Integer.parseInt(s); 으로 표현 가능
    }
}

//Python3
def solution(s):
    answer = 0
    i = 0
    sign = 1
    
    if s[0] == '+':
        i = 1
    elif s[0] == '-':
        i = 1
        sign = -1
    
    for i in range(i, len(s)):
        answer = answer * 10 + int(s[i])
    
    return answer * sign                           //return int(s) 으로 표현 가능
